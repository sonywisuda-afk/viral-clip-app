{
  "name": "@speedora/worker",
  "version": "0.1.0",
  "private": true,
  "description": "BullMQ job consumers for the AI video pipeline: transcribe (Whisper), detect-clips, render-clip (FFmpeg).",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "reencode:sources": "tsx src/scripts/reencode-existing-sources.ts",
    "evaluate:ocr": "tsx src/scripts/evaluate-ocr-classification.ts",
    "check:calibration-coverage": "tsx src/scripts/check-calibration-coverage.ts",
    "export:dataset": "tsx src/scripts/export-training-dataset.ts",
    "report:dataset-health": "tsx src/scripts/generate-dataset-report.ts",
    "pipeline:fusion-v3": "tsx src/scripts/run-fusion-v3-pipeline.ts",
    "verify:cross-feature": "tsx src/scripts/cross-feature-e2e/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/node": "^10.63.0",
    "@speedora/active-speaker-intelligence": "workspace:*",
    "@speedora/analytics-report": "workspace:*",
    "@speedora/audio-intelligence": "workspace:*",
    "@speedora/clip-scoring": "workspace:*",
    "@speedora/composition-intelligence": "workspace:*",
    "@speedora/contracts": "workspace:*",
    "@speedora/cutlist": "workspace:*",
    "@speedora/database": "workspace:^",
    "@speedora/dataset-quality": "workspace:*",
    "@speedora/editing-rhythm": "workspace:*",
    "@speedora/emoji-suggester": "workspace:*",
    "@speedora/facial-intelligence": "workspace:*",
    "@speedora/fusion-engine": "workspace:*",
    "@speedora/fusion-ml": "workspace:*",
    "@speedora/gesture-intelligence": "workspace:*",
    "@speedora/object-intelligence": "workspace:*",
    "@speedora/ocr-intelligence": "workspace:*",
    "@speedora/primary-subject": "workspace:*",
    "@speedora/reframe": "workspace:*",
    "@speedora/report-builder": "workspace:*",
    "@speedora/scene-intelligence": "workspace:*",
    "@speedora/seo-copy": "workspace:*",
    "@speedora/shared": "workspace:*",
    "@speedora/social": "workspace:*",
    "@speedora/speaker-diarization": "workspace:*",
    "@speedora/speaker-scoring": "workspace:*",
    "@speedora/storage": "workspace:^",
    "@speedora/subtitles": "workspace:*",
    "@speedora/thumbnail-selection": "workspace:*",
    "bullmq": "^5.7.8",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "ioredis": "5.10.1",
    "openai": "^6.45.0",
    "react": "^18"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "@types/node": "^20.12.12",
    "@types/react": "^18",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
