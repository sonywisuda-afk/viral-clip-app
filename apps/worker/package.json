{
  "name": "@viral-clip-app/worker",
  "version": "0.1.0",
  "private": true,
  "description": "BullMQ job consumers for the AI video pipeline: transcribe (Whisper), detect-clips, render-clip (FFmpeg).",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@viral-clip-app/shared": "workspace:*",
    "bullmq": "^5.7.8",
    "dotenv": "^17.4.2",
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  }
}
