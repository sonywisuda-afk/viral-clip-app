// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Mirrors VideoStatus in packages/shared/src/types/video.ts
enum VideoStatus {
  IMPORTING
  UPLOADED
  TRANSCRIBED
  CLIPS_DETECTED
  RENDERED
  FAILED
}

// Mirrors CaptionStyle in packages/shared/src/types/video.ts
enum CaptionStyle {
  DEFAULT
  KARAOKE
  BOLD_HIGHLIGHT
}

// Milestone 5C-B (AI Operations Dashboard) - the first role concept in this
// codebase. CREATOR (default) is every normal signup; the other three gate
// GET /ops/ai/* (RolesGuard) since that surface pools aggregate data across
// EVERY user's clips, not just the requester's own - a real access-control
// boundary, not a UX nicety. No self-service elevation endpoint exists -
// granted only via apps/api/src/scripts/grant-role.ts, see
// docs/operations-runbook.md.
enum UserRole {
  CREATOR
  ADMIN
  AI_ENGINEER
  OPERATOR
}

// Mirrors TranscriptionProvider in packages/shared/src/types/video.ts. Chosen
// per-video at upload/import time (see VideosService.upload/.importFromYoutube),
// not a persistent account setting - GROQ (Whisper large-v3-turbo) is the
// free default; OPENAI (Whisper-1) is the paid "premium" tier, gated by
// PremiumCredit below.
enum TranscriptionProvider {
  GROQ
  OPENAI
}

// One row per Midtrans Snap transaction for a single premium (OpenAI Whisper)
// transcription. Created PENDING when the user starts checkout, flipped to
// PAID/FAILED/EXPIRED by the Midtrans webhook (PaymentsService.handleWebhook -
// never trusted from the client-side Snap callback alone, since that can be
// spoofed or interrupted). videoId is set once an available PAID credit is
// atomically claimed by a video upload/import that requested OPENAI - null +
// status=PAID is exactly "unused, spendable credit" (see
// VideosService.consumePremiumCredit). One-time purchase, not a subscription:
// a credit is worth exactly one video's transcription, never renews.
enum PremiumCreditStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

model PremiumCredit {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          PremiumCreditStatus @default(PENDING)
  // Rupiah, whole units only (Midtrans gross_amount has no subunit for IDR) -
  // stored redundantly from the price constant at purchase time so a later
  // price change doesn't rewrite the meaning of past transactions.
  amount          Int
  // Midtrans's own transaction identifier - what its Snap API and webhook
  // notification both key off of. Prefixed/generated by PaymentsService, not
  // Midtrans itself, so it's known before the Snap API call that creates it.
  midtransOrderId String              @unique
  videoId         String?             @unique
  video           Video?              @relation(fields: [videoId], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([userId])
}

// Mirrors SocialPlatform in packages/shared/src/types/social.ts. YOUTUBE
// (Fase 6a) picked first for lowest-friction OAuth; TIKTOK (Fase 6d) added
// second; INSTAGRAM added third - see CLAUDE.md's "Publish Center" section
// for all three.
enum SocialPlatform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
}

// Mirrors PublishStatus in packages/shared/src/types/social.ts. SCHEDULED
// (Fase 6c) is a row waiting for its scheduledAt to arrive - the
// schedule-publish-clip poller (apps/worker) claims it (-> QUEUED) and
// enqueues the actual publish-clip job at that point, same as an immediate
// "publish now" skips SCHEDULED entirely and starts at QUEUED.
enum PublishStatus {
  SCHEDULED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
}

model User {
  id                          String    @id @default(cuid())
  email                       String    @unique
  // bcrypt hash - never the plaintext password.
  password                    String
  // Milestone 5C-B - see UserRole above. Every normal signup gets CREATOR.
  role                        UserRole  @default(CREATOR)
  // Forgot-password (Fase 8) - SHA-256 hash of a random token, never the raw
  // token itself (that only ever exists in the emailed reset link) - a DB
  // leak alone shouldn't be enough to reset anyone's password, same
  // reasoning as bcrypt-hashing the login password above. A new
  // forgot-password request overwrites both fields, implicitly invalidating
  // any earlier unused request - only the most recent one is ever honored.
  resetPasswordTokenHash      String?   @unique
  resetPasswordTokenExpiresAt DateTime?
  // Sprint 03d (Export Center roadmap) - Brand Report's minimal Brand Kit.
  // No new settings system - these live directly on User, same "smallest
  // viable" posture the roadmap called for. brandLogoUrl is a raw storage
  // key, never exposed as-is (same "never the raw key" convention as every
  // other resource) - GET /brand-kit/logo resolves it. All three null until
  // the user sets them; Brand Report falls back to default (unbranded)
  // styling when unset rather than blocking creation - same graceful-
  // degradation posture as a missing SMTP_HOST just logging a warning
  // elsewhere in this codebase.
  brandLogoUrl                String?
  brandPrimaryColor           String?
  brandSecondaryColor         String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  videos         Video[]
  socialAccounts SocialAccount[]
  premiumCredits           PremiumCredit[]
  activityEvents           ActivityEvent[]
  sentInvites              PendingInvite[]
  exportJobs               ExportJob[]
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  notificationWebhooks     NotificationWebhook[]
}

model Video {
  id                    String                @id @default(cuid())
  ownerId               String
  owner                 User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // Empty string while status is IMPORTING (see VideosService.importFromYoutube) -
  // apps/worker's import-youtube job fills in the real object storage key
  // once the download finishes. Kept non-nullable rather than String? so
  // every other reader of this field (findSourceOrThrow, transcribe/
  // render-clip's sourceUrl reads, etc.) doesn't need a null-check for a
  // state those code paths never actually run in.
  sourceUrl             String
  // Display name only - never used for storage keys/lookups (those are
  // always the cuid `id` or the object-storage key in sourceUrl). Direct
  // upload: the original filename (Express.Multer.File.originalname).
  // YouTube import: fetched separately by apps/worker's import-youtube job
  // (yt-dlp has no title available at the API-request instant, before the
  // download starts) - null until that job's first progress write, same
  // "arrives asynchronously" pattern as durationSeconds. Null for rows
  // created before this field existed - not backfilled (Dashboard falls
  // back to "Untitled video").
  title                 String?
  // Original youtube.com/youtu.be URL, set only by
  // VideosService.importFromYoutube() - null for a direct file upload.
  // Needed so VideosService.retry() can re-enqueue import-youtube (rather
  // than transcribe, which would run against the still-empty sourceUrl
  // above) if a video fails before the download ever finished.
  importSourceUrl       String?
  status                VideoStatus           @default(UPLOADED)
  durationSeconds       Float?
  // Bytes of the source file in object storage - direct upload sets this
  // synchronously from the already-in-memory multer buffer's length;
  // YouTube import sets it via an fs.stat() of the downloaded file right
  // before upload (same instant computeFileMd5Hex-style pattern render-clip
  // already uses for outputSizeBytes below). Feeds the Dashboard's per-owner
  // "Storage Used" stat cheaply from Postgres instead of scanning the whole
  // S3/R2/MinIO bucket (see packages/storage's getBucketUsage(), which is
  // bucket-wide and not owner-scoped). Null for pre-existing rows.
  sourceSizeBytes       Int?
  // Object storage key for a single extracted thumbnail frame
  // (thumbnails/<id>.webp - .jpg for rows extracted before Phase 2's WebP
  // switch, never backfilled, still served correctly since the API derives
  // Content-Type from this key's own extension), set by transcribe.worker.ts
  // (best-effort - a failed extraction never fails the transcribe job) right
  // after the source video is downloaded locally. Never exposed to the client
  // as this raw key - VideosService.mapVideoWithClips computes a
  // `/videos/:id/thumbnail` endpoint path instead, same treatment as
  // sourceUrl/downloadUrl. Null for pre-existing rows and while extraction is
  // still pending/failed - never backfilled.
  thumbnailUrl          String?
  // Phase 2 (image optimization roadmap) - a tiny (~8px-wide) blurred version
  // of thumbnailUrl, base64 data-URL encoded, generated in the same
  // best-effort extraction step. Small enough to return inline in the video
  // DTO (unlike the full thumbnail, which stays behind its own endpoint) so
  // the frontend has *something* to paint before the real image loads. Null
  // whenever thumbnailUrl is null (same lifecycle), and for pre-existing rows
  // predating this column.
  thumbnailBlurDataUrl  String?
  // Phase 3 (Hover Preview/Storyboard roadmap) - object storage keys for N
  // evenly-spaced frames (transcribe.worker.ts extracts each independently,
  // best-effort - some can fail while others succeed, so this is the actual
  // list of keys that succeeded, never a fabricated fixed-N array). Never
  // exposed to the client as raw keys - VideosService.mapVideoWithClips
  // computes `/videos/:id/storyboard/:index` endpoint paths instead, same
  // treatment as thumbnailUrl. Empty array (not null) once extraction has
  // run and found nothing; null only for pre-existing rows predating this
  // column.
  storyboardFrameUrls   Json?
  // Phase 3 (Animated Thumbnail roadmap) - object storage key for a short,
  // muted, looping animated WebP (extractAnimatedPreview in ffmpeg.ts, same
  // best-effort extraction step as thumbnailUrl above, a separate call so a
  // thumbnail failure doesn't imply an animated-preview failure or vice
  // versa). Never exposed to the client as a raw key - same
  // "/videos/:id/animated-thumbnail" endpoint-path treatment as thumbnailUrl.
  // Null while extraction is still pending/failed, or for pre-existing rows.
  animatedThumbnailUrl  String?
  // Phase 3 (Hover Preview roadmap) - object storage key for a longer,
  // smoother looping WebP than animatedThumbnailUrl above (same
  // extractAnimatedPreview() primitive, a longer/smoother config since this
  // is the main content of a hover interaction, not background decoration -
  // see ffmpeg.ts's own comment). A genuinely separate asset/column, not a
  // re-purposed animatedThumbnailUrl, because it's fetched on-demand only
  // (only on hover, never eagerly with the card) rather than always-shown.
  // Never exposed to the client as a raw key - same
  // "/videos/:id/hover-preview" endpoint-path treatment as thumbnailUrl.
  // Null while extraction is still pending/failed, or for pre-existing rows.
  hoverPreviewUrl       String?
  // Phase 4 of the thumbnail roadmap (AI Thumbnail Selection, Level 1 -
  // "which clip is the video's cover"). Set by render-clip.worker.ts once
  // every sibling clip has rendered and rankClips() has run, by COPYING
  // (never re-extracting) the rank-1 clip's own already-extracted
  // thumbnailUrl/thumbnailBlurDataUrl. Deliberately ADDITIVE, not an
  // overwrite of thumbnailUrl/thumbnailBlurDataUrl above - those keep
  // serving their existing purpose (a placeholder available from the
  // moment the raw source is downloaded, before any clip exists) - the API
  // layer (VideosService) prefers these when present, falling back to
  // thumbnailUrl/thumbnailBlurDataUrl otherwise. coverClipId is a plain id
  // reference, not a real Prisma relation (kept soft/nullable, same
  // treatment as Clip.highlightRank, so a cascade-deleted clip can't leave
  // a dangling required FK). Null for pre-existing rows, videos with no
  // rendered clips yet, or if this best-effort promotion step fails.
  coverClipId           String?
  coverThumbnailUrl     String?
  coverThumbnailBlurDataUrl String?
  // 0-100, real progress reported by import-youtube.worker.ts as yt-dlp
  // downloads the source - same "never fabricated" convention as
  // transcribeProgress below, and deliberately a separate column rather
  // than reusing that one: IMPORTING and (transcribe's) UPLOADED are
  // different stages, and overloading one column for both would make an
  // in-flight value ambiguous about which stage it belongs to. Null before
  // the import job has started or once status has moved past IMPORTING.
  // Reset to 0 at the start of every import attempt (including retries),
  // same reasoning as transcribeProgress.
  importProgress        Int?
  // 0-100, real progress reported by transcribe.worker.ts at each checkpoint
  // (source downloaded, each audio chunk transcribed) - never a fabricated/
  // interpolated animation. Null before the transcribe job has started or
  // once status has moved past UPLOADED (irrelevant at that point - the
  // frontend's per-stage progress bar only reads this while still on the
  // Transcribe stage). Reset to 0 at the start of every transcribe attempt
  // (including retries) so a re-run never shows a stale value from a
  // previous failed attempt.
  transcribeProgress    Int?
  // Chosen once at upload/import time (see TranscriptionProvider above) -
  // never changes afterward, including on retry (VideosService.retry()
  // re-enqueues transcribe with this same value). OPENAI requires an
  // available PremiumCredit to have been consumed by this video first (see
  // premiumCredit below); GROQ needs no payment at all.
  transcriptionProvider TranscriptionProvider @default(GROQ)
  // Speaker Intelligence roadmap, Milestone A (Voice Activity Detection) -
  // the FIRST whole-video intelligence signal stored as its own JSON blob
  // on Video, rather than distributed onto per-TranscriptSegment columns
  // (unlike diarization/vocal-emotion/loudness, which map cleanly onto
  // Whisper's own segment boundaries - see docs/ai/audio.md). VAD's
  // classified timeline (silence/speech/non_speech intervals) does NOT
  // align to segment boundaries - a silence can span multiple segments or
  // fall entirely between them - so it needs its own continuous timeline,
  // same "raw + features" pair convention as Clip's other AI-signal columns
  // (see database.md), just scoped to Video instead of Clip since VAD runs
  // once per video (same scope as diarizeSpeakers), not once per rendered
  // clip. Both null until detectVoiceActivity has run for this video, or
  // when it fails (never fails the transcribe job - same "optional signal"
  // fallback as diarization/vocal-emotion above).
  voiceActivitySegments Json?
  voiceActivityFeatures Json?
  // Speaker Intelligence roadmap, Milestone B (Turn/Silence/Overlap
  // Detection) - @speedora/speaker-diarization's deriveDiarizationFeatures()
  // output (speakerCount, per-turn segments, per-speaker total duration,
  // turnCount/switchCount, overlappingSpeech, silences), computed once per
  // video from diarizeSpeakers()'s own raw turn list right after diarization
  // runs (that list was previously discarded once assignSpeakerLabels
  // mapped it onto TranscriptSegment rows - see docs/ai/audio.md). Null
  // when diarization itself never produced any turns (no
  // HUGGINGFACE_TOKEN, gated-model rejection, or genuine detection
  // failure) - same "optional signal" fallback as voiceActivitySegments.
  diarizationFeatures   Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  transcriptSegments TranscriptSegment[]
  clips              Clip[]
  premiumCredit      PremiumCredit?
  statusEvents       VideoStatusEvent[]
  exportJobs         ExportJob[]

  @@index([ownerId])
}

// Audit trail for Video.status transitions (Fase 3 - DB+JSON-contract
// roadmap: an explicit history table for the pipeline's long-running job,
// rather than only ever seeing the current status). One row per transition.
// There's no separate "fromStatus" column - transitions for one video are
// always sequential (never processed by two workers concurrently), so the
// previous status is simply the prior row's toStatus when read ordered by
// createdAt, and storing it again would just be redundant with that
// ordering. Written exclusively by @speedora/database's updateVideoStatus()/
// recordVideoStatusEvent() helpers - see CLAUDE.md's Fase 3 section and
// ARCHITECTURE.md.
model VideoStatusEvent {
  id           String      @id @default(cuid())
  videoId      String
  video        Video       @relation(fields: [videoId], references: [id], onDelete: Cascade)
  toStatus     VideoStatus
  // Only set when toStatus is FAILED - the caught error's message, so a
  // failure can be diagnosed from a DB query alone without needing Sentry
  // access. Message text only (never the full error object/stack), same
  // "tags only" discipline already used at these call sites'
  // Sentry.captureException calls.
  errorMessage String?
  createdAt    DateTime    @default(now())

  @@index([videoId, createdAt])
}

// One row per timestamped line from the transcribe (Whisper) job.
// A clip's transcript is derived by querying segments within its time range,
// rather than duplicating segment data per clip.
model TranscriptSegment {
  id                         String   @id @default(cuid())
  videoId                    String
  video                      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  start                      Float
  end                        Float
  text                       String
  speaker                    String?
  // Top-1 label from a vocal (audio-based) emotion classifier - one of
  // "neu"/"hap"/"ang"/"sad" (superb/wav2vec2-base-superb-er's IEMOCAP
  // taxonomy - see CLAUDE.md's "Vocal Emotion Detection" section for why
  // this is a deliberately narrow, explicitly-heuristic signal, not a
  // trained/calibrated prediction). Null for segments too short to classify
  // meaningfully, or when detection wasn't run/failed for this video.
  emotion                    String?
  // Array of {word, start, end} (absolute seconds, same clock as start/end
  // above) from Whisper's word-level timestamp_granularities - null for
  // segments transcribed before this field existed (Fase 3 pasca-MVP; not
  // backfilled, see CLAUDE.md). A null/empty value here just means the
  // karaoke caption preset can't sync to this segment - render-clip falls
  // back to plain text for it rather than failing.
  words                      Json?
  // Fase 25 (Audio Intelligence, Phase A of the AI Fusion roadmap) - mean
  // RMS/peak level in dB over this segment's own audio slice (see
  // @speedora/audio-intelligence's analyzeAudioLoudness), computed via
  // ffmpeg's astats filter on the same full-track audio file diarization/
  // vocal-emotion already extract. Null for the same reasons emotion can be
  // null: detection wasn't run/failed for this video, or the slice was too
  // short/silent for ffmpeg to report a meaningful reading. Absolute dB
  // values are NOT calibrated/comparable across different source
  // recordings - only meaningful relative to other segments of the SAME
  // video.
  rmsDb                      Float?
  peakDb                     Float?
  // Words per second within this segment - pure math from Whisper's own
  // segment boundaries + word count, no audio analysis involved at all
  // (see @speedora/audio-intelligence's computeSpeakingRate). Null only
  // when this segment has no word-level data (see `words` above).
  speakingRateWordsPerSecond Float?
  createdAt                  DateTime @default(now())

  @@index([videoId])
}

// One row per candidate produced by the detect-clips job; outputUrl is set
// once the render-clip job finishes.
model Clip {
  id                      String       @id @default(cuid())
  videoId                 String
  video                   Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  startTime               Float
  endTime                 Float
  viralityScore           Float
  outputUrl               String?
  // Bytes of the rendered output in object storage - set alongside
  // outputUrl by render-clip.worker.ts via an fs.stat() of the rendered
  // file, right next to the existing computeFileMd5Hex() stream-based hash
  // (both read the same on-disk file before it's uploaded). Feeds the
  // Dashboard's per-owner "Storage Used" stat - see Video.sourceSizeBytes.
  // Null until the clip finishes rendering, or for pre-existing rows.
  outputSizeBytes         Int?
  // Object storage key for a single extracted thumbnail frame
  // (thumbnails/<id>.webp - .jpg for pre-Phase-2 rows, see Video.thumbnailUrl's
  // own comment), set by render-clip.worker.ts (best-effort) from the midpoint
  // of the RENDERED output - not the raw source - so the thumbnail matches
  // exactly what the viewer will see (crop/captions/B-roll already burned in).
  // Same "never exposed as a raw key" treatment as Video.thumbnailUrl above -
  // ClipsService.toDto()/VideosService.mapVideoWithClips compute a
  // `/clips/:id/thumbnail` endpoint path instead. Null until the clip
  // finishes rendering, extraction fails, or for pre-existing rows.
  thumbnailUrl            String?
  // Phase 2 (image optimization roadmap) - same tiny base64 blur-placeholder
  // treatment as Video.thumbnailBlurDataUrl above, inlined in the clip DTO.
  thumbnailBlurDataUrl    String?
  // Phase 3 (Hover Preview/Storyboard roadmap) - same treatment as
  // Video.storyboardFrameUrls above, extracted from the RENDERED output by
  // render-clip.worker.ts (same reasoning as thumbnailUrl - matches exactly
  // what the viewer sees).
  storyboardFrameUrls     Json?
  // Phase 3 (Animated Thumbnail roadmap) - same treatment as
  // Video.animatedThumbnailUrl above, extracted from the RENDERED output by
  // render-clip.worker.ts (same reasoning as thumbnailUrl - matches exactly
  // what the viewer sees).
  animatedThumbnailUrl    String?
  // Phase 3 (Hover Preview roadmap, "Clip Preview" on a clip card) - same
  // treatment as Video.hoverPreviewUrl above, extracted from the RENDERED
  // output by render-clip.worker.ts.
  hoverPreviewUrl         String?
  // Phase 4 of the thumbnail roadmap (AI Thumbnail Selection, Level 2) -
  // @speedora/thumbnail-selection's chosen in-clip timestamp (replacing the
  // naive (endTime - startTime) / 2 midpoint thumbnailUrl/
  // thumbnailBlurDataUrl above are extracted at), plus its explainability
  // breakdown. Deliberately NOT used to pick which clip is a video's cover -
  // see @speedora/contracts' thumbnail-selection.ts for the Level 1 vs.
  // Level 2 policy this column must never violate; that's highlightScore/
  // highlightRank's job. Null for pre-existing rows and if the render graph
  // hasn't run yet.
  thumbnailSelectionTimestamp Float?
  thumbnailSelectionBreakdown Json?
  thumbnailSelectionFallback  String?
  thumbnailSelectionReason    String?
  captionStyle            CaptionStyle @default(DEFAULT)
  // Suggested 3-second-opener hook line and social hashtags (without a
  // leading '#') from the same detect-clips LLM call that scores virality -
  // not baked into the rendered video, purely metadata for the
  // gallery/editor. hookText is nullable (the LLM call can fail/return
  // nothing without failing the whole job - see detectCandidates() in
  // detect-clips.worker.ts); hashtags defaults to an empty array rather
  // than nullable so callers never have to null-check it.
  hookText                String?
  hashtags                String[]     @default([])
  // Fase 8 (Content Intelligence) - same detect-clips LLM call as
  // viralityScore/hookText/hashtags above, extended with a multi-metric
  // breakdown and explainable-AI reasoning instead of one opaque number.
  // `scores` is one JSON blob (like TranscriptSegment.words) rather than a
  // column per metric - always read/written as a unit, and a future metric
  // addition doesn't need its own migration. Shape: { hookStrength,
  // educationalValue, curiosity, emotion, storytelling, novelty,
  // trustAuthority }, each 0-100 - see packages/shared's ClipScores.
  scores                  Json?
  // 1-2 sentence explanation of why this clip was picked - the
  // "explainable AI" requirement: a user should never have to take
  // viralityScore on faith.
  reason                  String?
  topics                  String[]     @default([])
  keywords                String[]     @default([])
  // e.g. "educate" | "entertain" | "persuade" | "inspire" | "story" | "other" -
  // free-form string, not a Postgres enum, since this is an LLM-classified
  // label (see CaptionStyle vs. this: CaptionStyle is a fixed, code-driven
  // set of render presets, this is open-ended content classification that
  // may need new values without a schema migration).
  intent                  String?
  // Call-to-action text detected in the clip, if any (e.g. "follow for
  // part 2", "link in bio") - null/empty when the clip has none.
  ctaText                 String?
  // Fase 23 (DB+JSON-contract roadmap, Fase 4 - new feature built purely via
  // the checklist) - deterministic keyword-pattern suggestions (see
  // @speedora/emoji-suggester), computed from this clip's own transcript
  // text at detect-clips time. Purely metadata (like hookText/hashtags),
  // never burned into the rendered video - defaults to an empty array
  // rather than nullable so callers never have to null-check it.
  emojiSuggestions        String[]     @default([])
  // Fase 26 (Scene Intelligence, AI Fusion roadmap Phase B) - clip-relative
  // (0 = clip start) timestamps of detected hard shot/scene cuts within
  // this clip, from @speedora/scene-intelligence's ffmpeg-based detector.
  // Empty array (not null) when analysis found no cuts or failed to run -
  // same "always an array" convention as topics/keywords/emojiSuggestions.
  sceneCuts               Float[]      @default([])
  // Batch SC-1 (Scene Intelligence taxonomy expansion, on top of Fase 26) -
  // one JSON array of @speedora/scene-intelligence's classifySceneCutTypes()
  // output ({t, type: 'hard_cut'|'fade'|'dissolve'}[], clip-relative
  // seconds, one entry per `sceneCuts` timestamp above) - a second ffmpeg
  // pass (blackdetect) over the same cuts, not a re-detection. Null (not an
  // empty array) when classification wasn't run or failed entirely for the
  // clip, distinct from an empty array (no cuts to classify at all) - same
  // convention as facialEmotions below.
  sceneCutEvents          Json?
  // Batch SC-2 (Scene Intelligence taxonomy expansion, continuing Batch
  // SC-1) - one JSON array of @speedora/scene-intelligence's
  // analyzeMotionEnergy() output ({t, motionEnergy}[], clip-relative
  // seconds, ~1 sample/second) - a SEPARATE signal from sceneCuts/
  // sceneCutEvents above (motion magnitude, not cut events). Json (not
  // Float[] like sceneCuts) because each sample is a {t, motionEnergy}
  // pair, not a bare number. Defaults to an empty JSON array (never null) -
  // analyzeMotionEnergy() itself never fails the job, same "always an
  // array" convention as sceneCuts.
  motionEnergy            Json         @default("[]")
  // Batch SC-2 - derived summary (see audioFeatures/sceneFeatures below) -
  // always computed (deriveMotionEnergyFeatures() never returns null, only
  // all-null fields for an empty `motionEnergy`), same "always populated"
  // convention as sceneFeatures/audioFeatures despite the nullable column
  // type (Prisma Json columns are declared nullable here purely so the
  // adapter isn't forced to fabricate a value before the first render).
  motionEnergyFeatures    Json?
  // Batch SC-3 (Scene Intelligence taxonomy expansion, continuing Batch
  // SC-1/SC-2) - one JSON array of @speedora/scene-intelligence's
  // detectCameraMotion() output ({t, dx, dy, scale, rotation, ecc}[],
  // clip-relative seconds, ~1 sample/second) - a Python/OpenCV subprocess
  // (ECC image alignment), unlike sceneCuts/motionEnergy above (both
  // ffmpeg-based). Null (not an empty array) when the analysis wasn't run
  // or failed entirely for the clip, same convention as facialEmotions
  // below (distinct from sceneCuts/motionEnergy's "always an array"
  // convention, which only applies to ffmpeg-based detectors that catch
  // their own failures).
  cameraMotion            Json?
  // Batch SC-3 - derived summary (see motionEnergyFeatures above) - null
  // exactly when `cameraMotion` above is null, same convention as
  // facialFeatures/gestureFeatures.
  cameraMotionFeatures    Json?
  // Taxonomy category F (Editing Rhythm, requested by user after Batch
  // SC-3) - @speedora/editing-rhythm's deriveEditingRhythmFeatures()
  // output (tempoScore/pacingScore/accelerationScore). NO separate "raw"
  // column - unlike every signal above, this one is a COMPOSITE (its input
  // is OTHER signals' already-computed sceneCuts/motionEnergy/features,
  // not a fresh subprocess/ffmpeg detector of its own), so there's no
  // independent raw timeline to persist here; the raw data it's built from
  // already lives in Clip.sceneCuts/Clip.motionEnergy. Always computed
  // when render-clip runs (never null in practice), same "always populated
  // despite a nullable column type" convention as sceneFeatures/
  // audioFeatures above.
  editingRhythmFeatures   Json?
  // Fase 27 (Facial Intelligence, AI Fusion roadmap Phase C) - one JSON
  // array of @speedora/facial-intelligence's per-sample output ({t, emotion,
  // score}[], clip-relative seconds), same "one JSON blob, not a column per
  // field" reasoning as `scores` above - always read/written as a unit.
  // Null (not an empty array) when the analysis wasn't run or failed
  // entirely for the clip - distinct from a sample within the array having
  // emotion/score null (no face found in that one sampled frame).
  facialEmotions          Json?
  // Fase 28 (Mini Fusion Engine v1 prep, AI Fusion roadmap Checkpoint 1) -
  // dense derived summaries per signal (see packages/contracts/src/
  // intelligence-signal.ts's raw/features convention and each module's own
  // deriveXFeatures()), separate from the raw timelines above
  // (sceneCuts/facialEmotions) and from TranscriptSegment's raw
  // rmsDb/peakDb/speakingRateWordsPerSecond columns (Fase 25) - the Fusion
  // Engine reads only these three columns, never the raw data directly.
  // Null when the underlying raw signal itself is empty/unavailable for
  // this clip (nothing to derive a summary from), not a fabricated
  // all-zero object.
  audioFeatures           Json?
  sceneFeatures           Json?
  facialFeatures          Json?
  // Fase 29/31 (Mini Fusion Engine v1 -> v2, AI Fusion roadmap - extends
  // Checkpoint 1/2) - @speedora/fusion-engine's computeHighlightScore()
  // output, computed from whichever of audioFeatures/sceneFeatures/
  // facialFeatures/gestureFeatures below are available for this clip.
  // `highlightScore` null means the sum of WEIGHTED signal contributions
  // was zero (not a fabricated 0/50) - a signal can be present in
  // `highlightBreakdown` with real data yet still not move this number if
  // its configured weight is 0 (e.g. gesture currently - see
  // @speedora/fusion-engine's weights.ts). `highlightBreakdown` (Json) now
  // holds FusionOutput's full per-FEATURE `contributions` array (v2:
  // feature-level, not one opaque sub-score per signal - see
  // packages/contracts/src/fusion.ts), `highlightExplainability` (Json)
  // holds the structured `topFactors`, `highlightConfidence` (0-1) is a
  // heuristic coverage+quality estimate (NOT a calibrated probability), and
  // `highlightReason` stays the human-readable sentence - same
  // "explainable AI" requirement as Fase 8's `reason`. All four are always
  // populated once computeHighlightScore runs, even when highlightScore
  // itself ends up null.
  highlightScore          Float?
  highlightBreakdown      Json?
  highlightExplainability Json?
  highlightConfidence     Float?
  highlightReason         String?
  // Rank among sibling clips of the same video by highlightScore, computed
  // once by @speedora/fusion-engine's rankClips() after every clip in the
  // video has finished rendering (see render-clip.worker.ts) - null until
  // then, and for videos with only one clip this is still populated (rank
  // 1) once that one clip is done, for consistency.
  highlightRank           Int?
  // Fase 30 (Gesture Intelligence, AI Fusion roadmap Checkpoint 2) - same
  // raw/features split as Scene/Facial Intelligence (Fase 26/28):
  // @speedora/gesture-intelligence's per-sample output ({t, gesture,
  // confidence}[], clip-relative seconds) and its derived summary
  // ({dominantGesture, gestureTransitions, peakConfidence, stability}).
  // gestures null (not []) when the whole analysis failed to run;
  // gestureFeatures null exactly when gestures is null.
  gestures                Json?
  gestureFeatures         Json?
  // Fase 32 (Mini Fusion Engine v2's 'llm' signal + Prediction/
  // Recommendation stages) - llmFeatures is the SAME object as `scores`
  // above (Fase 8's ClipScores), just snapshotted at render-clip time as
  // what was actually fed into computeHighlightScore - no separate
  // derivation step, unlike audio/scene/facial/gesture's *Features
  // columns, since ClipScores is already a per-clip Features-shaped object
  // (see @speedora/fusion-engine's feature-pipeline.ts). Null when the
  // clip had no scores at all (detect-clips' LLM call never ran/failed).
  // highlightPrediction/highlightRecommendation are computeHighlightScore's
  // own Prediction/Recommendation stage output - always populated once it
  // runs, same as highlightBreakdown/highlightExplainability/highlightReason.
  llmFeatures             Json?
  highlightPrediction     Json?
  highlightRecommendation Json?
  // AI Fusion roadmap's Face Intelligence initiative, Batch 1 - same raw/
  // features split as Scene/Facial/Gesture Intelligence above:
  // @speedora/facial-intelligence's detectFaceLandmarks() per-sample output
  // (MediaPipe FaceLandmarker: blendshapes/rotation/boundingBox/iris/eye-
  // corner points per sampled frame) and its derived summary (blinkRate,
  // averageSmile, averageMouthOpen, averageAbsoluteYaw/Pitch, position/
  // size/visibilityScore). Distinct from facialEmotions/facialFeatures
  // above (a separate subprocess/model producing an unrelated feature set -
  // expression classification vs. landmark geometry). faceLandmarks null
  // (not []) when the whole analysis failed to run; faceLandmarkFeatures
  // null exactly when faceLandmarks is null.
  faceLandmarks           Json?
  faceLandmarkFeatures    Json?
  // AI Fusion roadmap's Face Intelligence initiative, Batch 4.5 (Quality
  // Metrics & Telemetry) - explicitly NOT a scoring signal (user's own
  // framing: "bukan menambah AI baru"). Purely explainability/audit
  // telemetry over Batch 4's tracker (fragmentation rate, id switch count,
  // lost-track duration, re-identification success rate, per-track
  // breakdown, etc. - see @speedora/facial-intelligence's
  // deriveTrackingQualityMetrics). Not consumed by @speedora/fusion-engine
  // at all, unlike every other *Features column above. Null when
  // faceLandmarks itself is null (nothing to derive telemetry from).
  trackingQualityMetrics  Json?
  // Speaker Intelligence roadmap, Milestone A - Active Speaker Detection,
  // Speaker-Face Association, Lip Sync Verification
  // (@speedora/active-speaker-intelligence). All three are pure
  // aggregations over faceLandmarks + this clip's own transcript segments'
  // audio timing (no new subprocess) - see docs/ai/speaker-intelligence.md.
  // Not yet consumed by @speedora/fusion-engine (same "collect first,
  // calibrate later" treatment editingRhythm/gesture/faceGeometry got
  // before they were wired in - see ai/fusion.md). Null when faceLandmarks
  // itself is null (nothing to derive these from).
  activeSpeakerSamples    Json?
  speakerFaceAssociations Json?
  lipSyncVerifications    Json?
  // Speaker Intelligence roadmap, Milestone B - @speedora/speaker-diarization's
  // buildSpeakerTimeline()/detectSpeakerTransitions() output, fusing this
  // clip's own transcript-derived speaker turns with the Milestone A
  // signals just above (speakerFaceAssociations/activeSpeakerSamples) into
  // one unified per-clip timeline. Null when there are no speaker turns
  // covering this clip's time range at all (diarization never ran/found
  // nothing here) - not a fabricated empty timeline.
  speakerTimeline         Json?
  speakerTimelineFeatures Json?
  // Speaker Intelligence roadmap, Milestone C - @speedora/speaker-scoring's
  // deriveClipSpeakerScores() output: one entry per speaker in this clip's
  // speakerTimeline for confidence/engagement/importance, one entry per
  // timeline turn for highlightMoments (a speaker turn IS the moment
  // boundary - see that package's own comments). Re-runs
  // deriveFaceLandmarkFeatures/deriveAudioFeatures scoped to each
  // speaker's own face track/transcript segments - not a new raw signal,
  // a re-aggregation of faceLandmarks/audioFeatures/gestureFeatures/
  // speakerTimeline above. Null when speakerTimeline itself is null
  // (nothing to score).
  speakerConfidenceScores Json?
  speakerEngagementScores Json?
  speakerImportanceScores Json?
  speakerHighlightMoments Json?
  // AI Fusion roadmap's OCR initiative, Batch OCR-1 - @speedora/ocr-
  // intelligence's detectOcrText() per-sample output (Tesseract: text +
  // bounding box + confidence per detected on-screen text region, per
  // sampled frame). Raw only - no `ocrFeatures` companion column yet,
  // unlike every other detector's Batch 1: OCR-2 (cross-frame tracking +
  // rule-based Subtitle/Slide/Caption/Logo/Price/Name classification) is
  // what a derived-features summary would even mean here, so it's added
  // in that batch instead of as a premature placeholder now. Null (not
  // []) when the whole analysis failed to run.
  ocrText                 Json?
  // AI Fusion roadmap's OCR initiative, Batch OCR-2 - the "store
  // everything" layer between raw (ocrText) and aggregate (ocrFeatures):
  // @speedora/ocr-intelligence's trackOcrText()+classifyOcrTrack() output,
  // one entry per tracked on-screen text element across its lifetime, each
  // carrying every feature (position/size/duration/persistence/motion/
  // nearFace/regexFlags) PLUS the rule-fusion category/categoryConfidence
  // - user's own instruction: persist all of this now so a future trained
  // classifier could be built from it later. ocrFeatures is the dense
  // per-clip summary computeHighlightScore actually consumes (derived FROM
  // ocrTracks, same "raw/features" relationship as every other module's
  // pair, with this extra middle layer specific to OCR's multi-region-
  // per-frame shape). Both null exactly when ocrText is null.
  ocrTracks               Json?
  ocrFeatures             Json?
  // Object Intelligence roadmap, Batch OI-1 (Foundation) -
  // @speedora/object-intelligence's detectObjects() per-sample output
  // (MediaPipe Object Detector/EfficientDet-Lite0: category + bounding box
  // + confidence per detected entity, per sampled frame - a frame can have
  // multiple simultaneous objects, same multi-region-per-frame shape as
  // ocrText). Null (not []) when the whole analysis failed to run.
  objects                 Json?
  // The "store everything" layer between raw (objects) and aggregate
  // (objectFeatures): @speedora/object-intelligence's trackObjects()
  // output, one entry per tracked object across its lifetime (category,
  // averaged position/size/confidence, start/end time, appearsFrames,
  // persistenceScore) - same three-layer "raw/tracks/features" pattern as
  // ocrText/ocrTracks/ocrFeatures, generalized to a genuine multi-object
  // tracker (see track-objects.ts's own module comment for why OCR's
  // tracker, not Face Intelligence's single-track one, is the right
  // precedent). objectFeatures is the dense per-clip summary
  // computeHighlightScore actually consumes, derived FROM objectTracks.
  // Both null exactly when objects is null.
  objectTracks            Json?
  objectFeatures          Json?
  // Composition Intelligence roadmap, Batch RB-1/RB-2 (see docs/ai/
  // composition-intelligence.md) - @speedora/composition-intelligence's
  // deriveCompositionFeatures() output (ruleOfThirdsScore/headroomScore/
  // leadRoomScore/centeringScore/subjectLossRatio/compositionStability/
  // framingConsistency). NO separate "raw" column - same COMPOSITE
  // reasoning as editingRhythmFeatures above: its input is @speedora/
  // primary-subject's already-selected per-instant subject boxes (built
  // FROM Facial/Active-Speaker/Object Intelligence's already-computed
  // faceLandmarks/activeSpeakerSamples/objectTracks columns above, not a
  // fresh detector of its own), so there's no independent raw timeline to
  // persist here. Null when there were zero usable primary-subject samples
  // for this clip (not a fabricated all-null features object).
  compositionFeatures     Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  publishRecords PublishRecord[]
  jobExecutions  JobExecution[]

  @@index([videoId])
}

// Phase 1 instrumentation for the render-graph executor (apps/worker/src/render-graph/executor.ts
// - see ARCHITECTURE.md's "Composing multiple modules" section). One row per runGraph() call (i.e.
// one per render-clip job), parent to that run's NodeExecution rows below. Exists so Phase 2
// (weight calibration for the many Fusion Engine signals still at weight: 0 - Composition, Object,
// Speaker, Gesture, etc.) can query real production timing/failure-rate data instead of scraping
// logs - e.g. "which node fails most often", "which detector is most expensive", "does a
// high-confidence Composition signal actually move highlightScore". A job-level parent (rather than
// one flat node-row table) avoids repeating job-wide facts (graphVersion/workerVersion/gitCommit,
// total runtime) on every one of a job's ~30 node rows, and gives "total time for this clip's
// graph" a natural home instead of a SUM() over loosely-related rows.
//
// graphVersion/workerVersion/gitCommit exist because this pipeline is under active development
// (40+ migrations and counting) - without them, telemetry gathered today is unattributable to which
// version of the graph/detectors produced it once the graph looks different in six months.
// workerVersion/gitCommit are best-effort (see render-graph/telemetry.ts) and may be null in local
// dev where those env vars aren't set.
model JobExecution {
  id     String @id @default(cuid())
  clipId String
  clip   Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)

  graphVersion  String
  workerVersion String?
  gitCommit     String?

  startedAt       DateTime
  finishedAt      DateTime?
  totalDurationMs Int?

  createdAt DateTime @default(now())

  nodeExecutions NodeExecution[]

  @@index([clipId])
}

// One row per graph node per JobExecution. `level` is the node's position in the executor's
// Kahn's-algorithm level ordering (see executor.ts's computeLevels()) - not currently used for
// anything (all levels run sequentially today), but cheap to capture now and needed later to
// reconstruct a per-level timeline once `concurrency: 'level-parallel'` is ever turned on for real
// detectors (see ARCHITECTURE.md's executor section on why that's gated on a capacity-planning
// decision, not an architecture one).
model NodeExecution {
  id             String       @id @default(cuid())
  jobExecutionId String
  jobExecution   JobExecution @relation(fields: [jobExecutionId], references: [id], onDelete: Cascade)

  nodeId String
  level  Int
  status NodeExecutionStatus

  startedAt  DateTime
  finishedAt DateTime
  durationMs Int

  // Only set when status is FALLBACK or FAILED - the caught error's message (never the full error
  // object/stack), same "tags only" discipline as VideoStatusEvent.errorMessage.
  errorMessage String?
  // Deliberately unpopulated today - no node currently has a way to attach extra context beyond
  // its typed `Out` value (see executor.ts's GraphNode<Ctx, Out>), and inventing that plumbing
  // ahead of a concrete need would be exactly the kind of speculative abstraction this codebase
  // avoids. Reserved so a future per-node detail (e.g. frame count, detector confidence) doesn't
  // need its own migration - same "one JSON blob, not a column per metric" call already made for
  // Clip.scores.
  metadata     Json?

  @@index([nodeId, startedAt])
  @@index([jobExecutionId])
}

enum NodeExecutionStatus {
  SUCCESS
  FALLBACK
  FAILED
}

// A connected social platform account for publishing (Fase 6a - connect
// only, no publish action yet; see CLAUDE.md's "Publish Center" section).
// One user can connect multiple accounts, including multiple accounts on
// the same platform (e.g. two different YouTube channels).
model SocialAccount {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          SocialPlatform
  // The platform's own account/channel id - e.g. a YouTube channel id.
  // Used together with the unique constraint below to detect "already
  // connected" and upsert instead of creating a duplicate row when a user
  // reconnects the same account.
  platformAccountId String
  // Human-readable label for the "Connect account" UI - e.g. the YouTube
  // channel title. Refreshed from the platform on every (re)connect.
  displayName       String
  // AES-256-GCM encrypted (packages/social's token-encryption.ts, shared
  // with apps/worker's publish-clip job - see Fase 6b) - never plaintext at
  // rest. Stored as "<iv>:<authTag>:<ciphertext>", all hex-encoded.
  accessToken       String
  refreshToken      String
  tokenExpiresAt    DateTime
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  publishRecords PublishRecord[]

  @@unique([userId, platform, platformAccountId])
  @@index([userId])
}

// One row per publish attempt of a clip to a connected social account.
// scheduledAt is null for an immediate "publish now" (Fase 6b, status starts
// at QUEUED) and set for a future scheduled publish (Fase 6c, status starts
// at SCHEDULED until the schedule-publish-clip poller claims it).
model PublishRecord {
  id              String        @id @default(cuid())
  clipId          String
  clip            Clip          @relation(fields: [clipId], references: [id], onDelete: Cascade)
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  status          PublishStatus @default(QUEUED)
  // Set only for a scheduled publish (Fase 6c) - null means "publish now".
  scheduledAt     DateTime?
  publishedAt     DateTime?
  // The platform's own id for the published content (e.g. a YouTube video
  // id) - used to link back to it once published.
  platformPostId  String?
  errorMessage    String?
  // Latest-known snapshot only (Fase 6e), overwritten on every sync-publish-
  // stats run - not a historical time series. All null until the first sync
  // after publish, and permanently null for TikTok (Upload to Inbox mode
  // has no fetchable public video id to query stats for - see CLAUDE.md's
  // Fase 6e section).
  viewCount       Int?
  likeCount       Int?
  commentCount    Int?
  statsUpdatedAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  statsSnapshots PublishRecordStatsSnapshot[]

  @@index([clipId])
  @@index([socialAccountId])
  // schedule-publish-clip.worker.ts's poller runs this exact
  // (status, scheduledAt) combination every 60 seconds, forever, for the
  // life of the deployment - a composite index keeps that query cheap
  // regardless of how many PublishRecord rows accumulate over time.
  @@index([status, scheduledAt])
}

// Milestone 1 (Dataset & Feedback Loop): one append-only row per
// sync-publish-stats run, unlike PublishRecord's own viewCount/likeCount/
// commentCount which stay a mutable "latest snapshot". This is what lets us
// join AI features (Clip.highlightBreakdown etc.) against a real engagement
// trend instead of a single point-in-time number. watchTimeSeconds is only
// ever populated for Instagram today - YouTube/TikTok have no comparable
// metric available without the (deferred) YouTube Analytics API scope.
model PublishRecordStatsSnapshot {
  id               String        @id @default(cuid())
  publishRecordId  String
  publishRecord    PublishRecord @relation(fields: [publishRecordId], references: [id], onDelete: Cascade)
  capturedAt       DateTime      @default(now())
  viewCount        Int?
  likeCount        Int?
  commentCount     Int?
  shareCount       Int?
  watchTimeSeconds Float?
  // Heuristic, unvalidated composite - see computeEngagementScore in
  // packages/social. Null whenever viewCount is null/0.
  engagementScore  Float?

  @@index([publishRecordId, capturedAt])
}

// Sprint 1-2 (Dashboard Redesign, Product Experience track) - a
// user-facing activity feed, distinct from VideoStatusEvent above:
// VideoStatusEvent is an internal pipeline audit trail (one row per status
// transition, written by @speedora/database's updateVideoStatus() helper);
// ActivityEvent is a coarser, human-readable feed of things the DASHBOARD
// shows ("Video uploaded", "Clip generated", ...), written from a handful
// of call sites (VideosService.upload()/importFromYoutube(),
// render-clip.worker.ts, ClipsController's download route, TeamService's
// invite endpoint) via the new recordActivityEvent() helper, same
// "append-only, written by one shared helper" shape as VideoStatusEvent.
enum ActivityEventType {
  VIDEO_UPLOADED
  CLIP_GENERATED
  CLIP_EXPORTED
  MEMBER_INVITED
}

model ActivityEvent {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActivityEventType
  videoId   String?
  clipId    String?
  // Free-form display context (e.g. { title } for a video/clip that may
  // since have been deleted) - kept as JSON rather than a live relation
  // read at feed-render time so a deleted video/clip doesn't blank out its
  // own history entry.
  metadata  Json?
  createdAt DateTime          @default(now())

  @@index([userId, createdAt])
}

// Notification Center Sprint 4A (Product Experience track) - in-app-only
// delivery. Deliberately a SEPARATE model from ActivityEvent, not a
// rename/extension of it: ActivityEvent stays a passive "what happened" feed
// (Dashboard's Activity Timeline); Notification is "what was actually
// delivered to a channel" and carries read-state (readAt), which
// ActivityEvent has never needed. Grown incrementally per shipped
// trigger/rule, same discipline as ActivityEventType/ExportType. The
// Collaboration-blocked events (Review Request/Comment/Approval/Member
// Invitation accepted) remain unscheduled.
enum NotificationType {
  UPLOAD_COMPLETE
  CLIP_READY
  EXPORT_READY
  RENDER_FAILED
  // Sprint 4C (Alert Engine) - the first state-based (not event-driven)
  // types, backed by AlertState below. See
  // packages/database/src/alert-engine.ts.
  STORAGE_WARNING
  CREDIT_WARNING
}

// Only IN_APP for Sprint 4A. Milestone 04d wired SLACK/DISCORD/WEBHOOK -
// each an outbound delivery surface a user can independently enable/disable
// per NotificationType (see NotificationPreference below), backed by a
// destination configured once via NotificationWebhook. EMAIL/TELEGRAM stay
// deferred (04e/unscheduled), same incremental-enum discipline as
// ExportType.
enum NotificationChannel {
  IN_APP
  SLACK
  DISCORD
  WEBHOOK
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  videoId   String?
  clipId    String?
  // Same "free-form display context, JSON not a live relation" reasoning as
  // ActivityEvent.metadata - e.g. { errorMessage } for RENDER_FAILED, kept
  // out of `body` itself so raw internal error text is never rendered
  // verbatim to the end user.
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  // Serves the unread-count endpoint's count({ where: { userId, readAt:
  // null } }) query.
  @@index([userId, readAt])
}

// Was schema-only in Sprint 4A; wired in Sprint 4B (IN_APP only) and
// Milestone 04d (SLACK/DISCORD/WEBHOOK). A genuine per-(user, type, channel)
// matrix, not a JSON blob on User - different shape from Brand Kit's few
// singleton columns (see this file's own comment on User.brandLogoUrl for
// why THAT stayed flat). `config` (Sprint 4B) holds `{ toast?: boolean }` on
// the IN_APP row only - toast is a client-only ephemeral presentation of a
// Notification row that already exists via IN_APP, not a distinct delivery
// mechanism, so it's NOT a second NotificationChannel value (that would
// create a reachable-but-meaningless enabled=false/toast=true state -
// nothing is ever created to toast about). `config` stays unused for
// SLACK/DISCORD/WEBHOOK rows - the actual destination (URL) lives on
// NotificationWebhook below, not here, since it's one account-level secret
// per channel, not something that varies per NotificationType.
model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  config    Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, type, channel])
}

// Milestone 04d - one row per (userId, channel), an account-level outbound
// destination shared by every enabled NotificationType for that channel.
// Mirrors SocialAccount's "one connected destination, referenced by many
// downstream rows" shape, without the OAuth complexity - just a single
// secret URL. IN_APP is deliberately excluded (rejected at the service
// layer, not the schema) since it has no external destination to configure.
model NotificationWebhook {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  // AES-256-GCM encrypted at rest via webhook-encryption.ts (same pattern
  // as SocialAccount.accessToken/refreshToken - see that field's own
  // comment) - stored as "<iv>:<authTag>:<ciphertext>", all hex. Never
  // decrypted back to a client - NotificationWebhookDto only ever exposes
  // `configured: boolean`.
  url       String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, channel])
}

// Sprint 4C (Alert Engine) - durable "is this alert instance currently
// active" tracker, one row per AlertInstance.dedupeKey ('storage-warning'
// for the one system-wide rule, `credit-warning:${userId}` for the
// per-user rule). Presence of a row = already notified, don't re-notify
// while still breached; absence = not active, same "absence = default"
// convention as NotificationPreference. Deleted (not flagged) the moment a
// condition clears, so a later re-breach starts a fresh incident with a
// fresh activeSince - mirrors AlertStateTracker's in-memory
// since-reset-on-absence behavior (apps/api/src/monitoring/alert-state.ts),
// made durable across apps/worker restarts, which that in-memory tracker
// explicitly does not survive (see its own doc comment) and which this
// milestone's de-dup need cannot tolerate.
model AlertState {
  id          String   @id @default(cuid())
  dedupeKey   String   @unique
  activeSince DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Sprint 1-2's Invite Member quick action. Deliberately minimal per explicit
// product direction: no Team/Membership schema, no shared video/clip
// access, no workspace switching, no role enforcement - `role` is captured
// from the modal's selector and stored for display only, not read by any
// permission check anywhere. No status/accept flow either - this is a
// one-way "we sent an email" log, not a real invitation lifecycle.
enum PendingInviteRole {
  OWNER
  EDITOR
  VIEWER
}

model PendingInvite {
  id        String            @id @default(cuid())
  inviterId String
  inviter   User              @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  email     String
  role      PendingInviteRole
  createdAt DateTime          @default(now())

  @@index([inviterId, createdAt])
}

// Sprint 03c (Export Center roadmap) - tracks one async report-generation
// job (currently only PDF; EXCEL/etc. join this enum in Sprint 03d without
// a schema change to ExportJob itself). A concrete videoId relation, not a
// generic Json "scope" blob (the original 03a-era sketch) - now that this
// model actually exists, scope is always exactly one video, and a real FK
// avoids the TS2742 declaration-emit trap this codebase has hit repeatedly
// with untyped Json columns (see ARCHITECTURE.md). No retry-count/backoff
// tracking here - unlike PublishRecord, ExportJob jobs don't get automatic
// BullMQ retry (same "fails once, user re-triggers" convention as every
// pipeline job except publish-clip); a failed row is simply terminal.
// Sprint 03d - EXCEL/HIGHLIGHT_REPORT/BRAND_REPORT all reuse the exact same
// video-scoped data pipeline PDF already uses (buildVideoReportInputFromPrisma
// -> buildVideoReportData) - only the rendering differs. ANALYTICS_REPORT
// (Analytics Report) is the one account-wide type - AnalyticsService.getOverview/
// getPerformance are userId-scoped across every video, never one videoId, so
// ExportJob.videoId became nullable to accommodate it (see below). Built via
// its own pipeline: packages/analytics-report's buildAnalyticsReportData, fed
// by apps/worker's own account-wide adapter (build-analytics-report-input.ts),
// never the video-scoped one the other 4 types share.
enum ExportType {
  PDF
  EXCEL
  HIGHLIGHT_REPORT
  BRAND_REPORT
  ANALYTICS_REPORT
}

enum ExportJobStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model ExportJob {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Nullable since ANALYTICS_REPORT is account-wide, not tied to one video -
  // every other ExportType still always sets this. Postgres indexes nullable
  // columns fine; the index below simply never matches ANALYTICS_REPORT rows
  // (they're queried by `type`, not `videoId`, in ExportService.listRecent).
  videoId    String?
  video      Video?          @relation(fields: [videoId], references: [id], onDelete: Cascade)
  type       ExportType      @default(PDF)
  status     ExportJobStatus @default(PENDING)
  // Object storage key, set only once status reaches READY - never exposed
  // to the client as this raw key, same "endpoint path instead" treatment
  // as every other resource in this codebase (see ExportJobDto.resultUrl).
  resultUrl  String?
  failReason String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([userId, createdAt])
  // Recent Exports / Persistent Export History - backs GET /export?videoId=
  // (ExportService.listRecent's `WHERE videoId = ? ORDER BY createdAt DESC
  // LIMIT 10`), a real repeated query this feature introduces.
  @@index([videoId, createdAt])
}
