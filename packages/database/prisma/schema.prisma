// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Mirrors VideoStatus in packages/shared/src/types/video.ts
enum VideoStatus {
  UPLOADED
  TRANSCRIBED
  CLIPS_DETECTED
  RENDERED
  FAILED
}

// Mirrors CaptionStyle in packages/shared/src/types/video.ts
enum CaptionStyle {
  DEFAULT
  KARAOKE
  BOLD_HIGHLIGHT
}

// Mirrors SocialPlatform in packages/shared/src/types/social.ts. YOUTUBE
// (Fase 6a) picked first for lowest-friction OAuth; TIKTOK (Fase 6d) added
// second - see CLAUDE.md's "Publish Center" section for both.
enum SocialPlatform {
  YOUTUBE
  TIKTOK
}

// Mirrors PublishStatus in packages/shared/src/types/social.ts. SCHEDULED
// (Fase 6c) is a row waiting for its scheduledAt to arrive - the
// schedule-publish-clip poller (apps/worker) claims it (-> QUEUED) and
// enqueues the actual publish-clip job at that point, same as an immediate
// "publish now" skips SCHEDULED entirely and starts at QUEUED.
enum PublishStatus {
  SCHEDULED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  // bcrypt hash - never the plaintext password.
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos         Video[]
  socialAccounts SocialAccount[]
}

model Video {
  id              String      @id @default(cuid())
  ownerId         String
  owner           User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sourceUrl       String
  status          VideoStatus @default(UPLOADED)
  durationSeconds Float?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  transcriptSegments TranscriptSegment[]
  clips              Clip[]

  @@index([ownerId])
}

// One row per timestamped line from the transcribe (Whisper) job.
// A clip's transcript is derived by querying segments within its time range,
// rather than duplicating segment data per clip.
model TranscriptSegment {
  id        String   @id @default(cuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  start     Float
  end       Float
  text      String
  speaker   String?
  // Array of {word, start, end} (absolute seconds, same clock as start/end
  // above) from Whisper's word-level timestamp_granularities - null for
  // segments transcribed before this field existed (Fase 3 pasca-MVP; not
  // backfilled, see CLAUDE.md). A null/empty value here just means the
  // karaoke caption preset can't sync to this segment - render-clip falls
  // back to plain text for it rather than failing.
  words     Json?
  createdAt DateTime @default(now())

  @@index([videoId])
}

// One row per candidate produced by the detect-clips job; outputUrl is set
// once the render-clip job finishes.
model Clip {
  id            String       @id @default(cuid())
  videoId       String
  video         Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  startTime     Float
  endTime       Float
  viralityScore Float
  outputUrl     String?
  captionStyle  CaptionStyle @default(DEFAULT)
  // Suggested 3-second-opener hook line and social hashtags (without a
  // leading '#') from the same detect-clips LLM call that scores virality -
  // not baked into the rendered video, purely metadata for the
  // gallery/editor. hookText is nullable (the LLM call can fail/return
  // nothing without failing the whole job - see detectCandidates() in
  // detect-clips.worker.ts); hashtags defaults to an empty array rather
  // than nullable so callers never have to null-check it.
  hookText      String?
  hashtags      String[]     @default([])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  publishRecords PublishRecord[]

  @@index([videoId])
}

// A connected social platform account for publishing (Fase 6a - connect
// only, no publish action yet; see CLAUDE.md's "Publish Center" section).
// One user can connect multiple accounts, including multiple accounts on
// the same platform (e.g. two different YouTube channels).
model SocialAccount {
  id       String         @id @default(cuid())
  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform SocialPlatform
  // The platform's own account/channel id - e.g. a YouTube channel id.
  // Used together with the unique constraint below to detect "already
  // connected" and upsert instead of creating a duplicate row when a user
  // reconnects the same account.
  platformAccountId String
  // Human-readable label for the "Connect account" UI - e.g. the YouTube
  // channel title. Refreshed from the platform on every (re)connect.
  displayName String
  // AES-256-GCM encrypted (packages/social's token-encryption.ts, shared
  // with apps/worker's publish-clip job - see Fase 6b) - never plaintext at
  // rest. Stored as "<iv>:<authTag>:<ciphertext>", all hex-encoded.
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  publishRecords PublishRecord[]

  @@unique([userId, platform, platformAccountId])
  @@index([userId])
}

// One row per publish attempt of a clip to a connected social account.
// scheduledAt is null for an immediate "publish now" (Fase 6b, status starts
// at QUEUED) and set for a future scheduled publish (Fase 6c, status starts
// at SCHEDULED until the schedule-publish-clip poller claims it).
model PublishRecord {
  id              String         @id @default(cuid())
  clipId          String
  clip            Clip           @relation(fields: [clipId], references: [id], onDelete: Cascade)
  socialAccountId String
  socialAccount   SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  status          PublishStatus  @default(QUEUED)
  // Set only for a scheduled publish (Fase 6c) - null means "publish now".
  scheduledAt     DateTime?
  publishedAt     DateTime?
  // The platform's own id for the published content (e.g. a YouTube video
  // id) - used to link back to it once published.
  platformPostId String?
  errorMessage   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([clipId])
  @@index([socialAccountId])
}
