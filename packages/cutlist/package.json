{
  "name": "@speedora/cutlist",
  "version": "0.1.0",
  "private": true,
  "description": "Stateless module (JSON-in/JSON-out): computes silence/filler cut ranges and post-cut junction timestamps from word-level transcript data. No DB/queue access at all; see root ARCHITECTURE.md. Consumed by apps/worker's render-clip adapter and ffmpeg.ts.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@speedora/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
