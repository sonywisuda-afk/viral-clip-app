# Postgres (used by docker-compose and apps/api)
POSTGRES_USER=viralclip
POSTGRES_PASSWORD=viralclip
POSTGRES_DB=viralclip
POSTGRES_PORT=5432
DATABASE_URL=postgresql://viralclip:viralclip@localhost:5432/viralclip

# Redis (used by docker-compose, apps/api, and apps/worker BullMQ queues)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Automated Postgres + object-storage backups (ops/backup, docker-compose's
# `backup` service - see docs/backup-restore.md). All optional - unset
# values fall back to the defaults noted here.
# How often the backup service runs both backups (also runs once
# immediately on container start).
BACKUP_INTERVAL_HOURS=24
# Backups older than this are pruned after each successful run.
BACKUP_RETENTION_DAYS=14
# How long apps/api's GET /backups tolerates no fresh successful backup
# before reporting stale: true.
BACKUP_STALE_AFTER_HOURS=48

# Object storage (used by apps/api and apps/worker via packages/storage) for
# uploaded videos and rendered clips. Any S3-compatible provider works
# (currently configured for Cloudflare R2) - just point STORAGE_ENDPOINT at
# a different provider to switch.
# R2 endpoint format: https://<account_id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=your_bucket_name
STORAGE_ACCESS_KEY_ID=your_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_secret_access_key
STORAGE_FORCE_PATH_STYLE=true

# apps/api
API_PORT=3001
# Allowed CORS origin for browser requests from apps/web
WEB_ORIGIN=http://localhost:3000
# Secret used to sign auth JWTs. Generate your own: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# apps/web
NEXT_PUBLIC_API_URL=http://localhost:3001
# Premium transcription checkout (Midtrans Snap.js) - the public client key
# from the same Midtrans account as MIDTRANS_SERVER_KEY/MIDTRANS_CLIENT_KEY
# below. Safe to expose to the browser (that's what it's for); leaving it
# unset just means the "Bayar & Pakai OpenAI" button fails with a clear
# error instead of a broken Snap.js embed. See the Midtrans setup section
# further down for where to get it.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# 'true' loads Midtrans's production Snap.js instead of sandbox. Must match
# MIDTRANS_IS_PRODUCTION below - a mismatch means the client key and server
# key belong to different environments and checkout will fail.
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# apps/worker - Groq Whisper large-v3-turbo (the free, default transcription
# tier every video uses unless the user pays for premium - see CLAUDE.md's
# "Premium Transcription" section). Required at boot, unlike OPENAI_API_KEY
# below - get a free key at https://console.groq.com/keys.
GROQ_API_KEY=your_groq_key_here
# apps/worker - OpenAI Whisper (whisper-1), the paid "premium" transcription
# tier gated by a PremiumCredit (see MIDTRANS_* below). Optional - a worker
# without this set still boots and processes every free (Groq) transcription
# normally; only a premium job fails, clearly, until it's set. Get a key at
# https://platform.openai.com/api-keys.
OPENAI_API_KEY=your_openai_key_here
# apps/worker - speaker diarization (see CLAUDE.md's Fase 12 section).
# Optional - a worker without this set still transcribes/clips/renders
# normally, just without speaker labels (transcribe.worker.ts treats a
# missing token the same as any other diarization failure: skip it for this
# video, don't fail the job). pyannote/speaker-diarization-community-1 is
# gated - before this works you must (1) create a free Hugging Face
# account, (2) accept its terms at
# https://huggingface.co/pyannote/speaker-diarization-community-1, then
# (3) generate a read-scoped token at https://huggingface.co/settings/tokens.
# (Not speaker-diarization-3.1 - see diarize_speakers.py's comment on why.)
HUGGINGFACE_TOKEN=
# apps/worker - Auto B-roll (Fase 15, extended to 3 providers behind an
# Adapter pattern in Fase 16 - see CLAUDE.md). All three keys below are
# independently optional - StockAssetService (apps/worker/src/assets/)
# tries whichever providers ARE configured and simply skips ones that
# aren't; with none configured, every clip still renders normally, just
# without B-roll cutaways.
#
# Pexels (Tier 1 - video). Free, no payment method required - sign up at
# https://www.pexels.com/api/ and the key is shown immediately on your
# dashboard.
PEXELS_API_KEY=
# Pixabay (Tier 1 - video). Free, no payment method required - sign up at
# https://pixabay.com/api/docs/ ("Get started" -> your API key is on your
# account page).
PIXABAY_API_KEY=
# Unsplash (Tier 2 - photos only, tried after Pexels/Pixabay find nothing).
# Free - create an app at https://unsplash.com/oauth/applications to get an
# Access Key. Demo apps are capped at 50 requests/hour, which
# StockAssetService's per-keyword caching helps stay under.
UNSPLASH_ACCESS_KEY=
# Path to the ffmpeg binary used by the render-clip job. Defaults to "ffmpeg"
# (assumes it's on PATH); override with an absolute path if it isn't.
FFMPEG_PATH=ffmpeg
# Path to the yt-dlp binary used by the import-youtube job. Defaults to
# "yt-dlp" (assumes it's on PATH, e.g. via `pip install yt-dlp`); override
# with an absolute path if it isn't.
YTDLP_PATH=yt-dlp

# Observability (apps/api and apps/worker both read this). Optional - leave
# blank/unset in local dev, Sentry.init() just disables itself without a
# dsn. Get your own project DSN from sentry.io; this is a placeholder, not
# a real value.
SENTRY_DSN=

# Forgot-password email (apps/api's MailService, via nodemailer). Optional -
# leave SMTP_HOST blank/unset in local dev and the reset link is logged to
# the apps/api console instead of emailed, so the feature is still usable
# without an SMTP account.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@speedora.local

# Publish Center - YouTube OAuth connect (Fase 6a) and publish-clip uploads
# (Fase 6b). Read by both apps/api (connect flow) and apps/worker
# (publish-clip job, via @speedora/social) - optional in both; apps/api
# just 503s on GET /social/youtube/connect, and apps/worker just fails the
# publish-clip job (reported to Sentry) until they're set. Create your own
# OAuth client at https://console.cloud.google.com/apis/credentials (type
# "Web application"), enable the YouTube Data API v3, and add
# http://localhost:3001/social/youtube/callback as an authorized redirect URI.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Publish Center - TikTok OAuth connect + publish-clip uploads (Fase 6d).
# Same optional treatment as the Google vars above. Create your own app at
# https://developers.tiktok.com/apps (Login Kit + Content Posting API
# products, video.upload scope only - see CLAUDE.md's Fase 6d section for
# why this is "Upload to Inbox", not Direct Post), and add
# http://localhost:3001/social/tiktok/callback as a redirect URI.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Publish Center - Instagram Reels via Facebook Login (Fase 6d follow-up).
# Same optional treatment as the vars above. Requires the connecting user's
# Instagram account to be a Business/Creator account linked to a Facebook
# Page they manage - see CLAUDE.md's Fase 6d "Instagram" section for why
# this flow (over Meta's newer standalone Instagram Login) was chosen.
# Create your own app at https://developers.facebook.com/apps (Facebook
# Login + Instagram Graph API products), and add
# http://localhost:3001/social/instagram/callback as a valid OAuth redirect URI.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# apps/api's own base URL as seen by the browser - used to build the
# YouTube/TikTok/Instagram OAuth redirect_uri. Must exactly match a redirect
# URI registered on all three OAuth clients above. Defaults to
# http://localhost:$API_PORT if unset.
API_BASE_URL=http://localhost:3001
# AES-256-GCM key used to encrypt SocialAccount access/refresh tokens at
# rest (any platform). Generate your own: openssl rand -hex 32 - unlike the
# vars above, there's no safe default for an encryption key, so leaving this
# unset just means connecting an account will fail loudly instead of
# storing tokens insecurely.
TOKEN_ENCRYPTION_KEY=

# Premium transcription checkout - Midtrans Snap (pay-per-use, Rp 10.000 per
# video for OpenAI Whisper; see CLAUDE.md's "Premium Transcription" section).
# Read by apps/api's PaymentsModule - optional, same posture as the OAuth
# vars above: POST /payments/premium-transcription/checkout just 503s until
# these are set, everything else (including free Groq transcription) keeps
# working. Get sandbox keys from https://dashboard.sandbox.midtrans.com
# (Settings -> Access Keys) after registering at https://midtrans.com -
# sandbox keys work immediately, no approval wait, and simulate real
# payments end-to-end without moving real money.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# 'true' switches to Midtrans's production API host. Leave 'false'/unset
# until you've moved off sandbox keys above - see
# NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION above, which must match.
MIDTRANS_IS_PRODUCTION=false
# Must exactly match the Server Key used to sign notifications - Midtrans's
# webhook (POST /payments/webhook/midtrans) verifies every notification's
# signature against this key before trusting it (see
# apps/api/src/payments/midtrans-signature.util.ts). Register this webhook
# URL in the Midtrans dashboard (Settings -> Configuration -> Payment
# Notification URL): http://localhost:3001/payments/webhook/midtrans in
# dev - use a public tunnel (e.g. ngrok) if testing a real Snap payment
# locally, since Midtrans's servers can't reach localhost directly.

# Fusion Engine v3 (Milestone 2A, see docs/ai/fusion-v3.md) - read by
# packages/fusion-ml's isFusionV3Enabled(). Currently read by NOTHING in
# apps/worker/apps/api - v2 (@speedora/fusion-engine) is the only engine
# that actually runs, and this flag has no live call site yet. Reserved for
# whichever future milestone wires a real v3 Predictor into
# render-clip.worker.ts. Optional - unset/anything other than the literal
# string 'true' means "disabled," the safe default.
FUSION_ENGINE_V3_ENABLED=false
