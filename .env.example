# Postgres (used by docker-compose and apps/api)
POSTGRES_USER=viralclip
POSTGRES_PASSWORD=viralclip
POSTGRES_DB=viralclip
POSTGRES_PORT=5432
DATABASE_URL=postgresql://viralclip:viralclip@localhost:5432/viralclip

# Redis (used by docker-compose, apps/api, and apps/worker BullMQ queues)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# apps/api
API_PORT=3001
# Local disk storage for uploaded videos (resolved relative to apps/api's cwd)
UPLOAD_DIR=uploads

# apps/web
NEXT_PUBLIC_API_URL=http://localhost:3001

# apps/worker (Whisper transcription via OpenAI's audio API)
OPENAI_API_KEY=your_key_here
