# Postgres (used by docker-compose and apps/api)
POSTGRES_USER=viralclip
POSTGRES_PASSWORD=viralclip
POSTGRES_DB=viralclip
POSTGRES_PORT=5432
DATABASE_URL=postgresql://viralclip:viralclip@localhost:5432/viralclip

# Redis (used by docker-compose, apps/api, and apps/worker BullMQ queues)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Object storage (used by apps/api and apps/worker via packages/storage) for
# uploaded videos and rendered clips. Any S3-compatible provider works
# (currently configured for Cloudflare R2) - just point STORAGE_ENDPOINT at
# a different provider to switch.
# R2 endpoint format: https://<account_id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=your_bucket_name
STORAGE_ACCESS_KEY_ID=your_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_secret_access_key
STORAGE_FORCE_PATH_STYLE=true

# apps/api
API_PORT=3001
# Allowed CORS origin for browser requests from apps/web
WEB_ORIGIN=http://localhost:3000
# Secret used to sign auth JWTs. Generate your own: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# apps/web
NEXT_PUBLIC_API_URL=http://localhost:3001

# apps/worker (Whisper transcription via OpenAI's audio API)
OPENAI_API_KEY=your_key_here
# Path to the ffmpeg binary used by the render-clip job. Defaults to "ffmpeg"
# (assumes it's on PATH); override with an absolute path if it isn't.
FFMPEG_PATH=ffmpeg

# Observability (apps/api and apps/worker both read this). Optional - leave
# blank/unset in local dev, Sentry.init() just disables itself without a
# dsn. Get your own project DSN from sentry.io; this is a placeholder, not
# a real value.
SENTRY_DSN=

# Publish Center - YouTube OAuth connect (Fase 6a) and publish-clip uploads
# (Fase 6b). Read by both apps/api (connect flow) and apps/worker
# (publish-clip job, via @viral-clip-app/social) - optional in both; apps/api
# just 503s on GET /social/youtube/connect, and apps/worker just fails the
# publish-clip job (reported to Sentry) until they're set. Create your own
# OAuth client at https://console.cloud.google.com/apis/credentials (type
# "Web application"), enable the YouTube Data API v3, and add
# http://localhost:3001/social/youtube/callback as an authorized redirect URI.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Publish Center - TikTok OAuth connect + publish-clip uploads (Fase 6d).
# Same optional treatment as the Google vars above. Create your own app at
# https://developers.tiktok.com/apps (Login Kit + Content Posting API
# products, video.upload scope only - see CLAUDE.md's Fase 6d section for
# why this is "Upload to Inbox", not Direct Post), and add
# http://localhost:3001/social/tiktok/callback as a redirect URI.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# apps/api's own base URL as seen by the browser - used to build both the
# YouTube and TikTok OAuth redirect_uri. Must exactly match a redirect URI
# registered on both OAuth clients above. Defaults to
# http://localhost:$API_PORT if unset.
API_BASE_URL=http://localhost:3001
# AES-256-GCM key used to encrypt SocialAccount access/refresh tokens at
# rest (any platform). Generate your own: openssl rand -hex 32 - unlike the
# vars above, there's no safe default for an encryption key, so leaving this
# unset just means connecting an account will fail loudly instead of
# storing tokens insecurely.
TOKEN_ENCRYPTION_KEY=
