# Production-only overrides, layered ON TOP of .env by
# docker-compose.prod.yml (env_file: [.env, .env.production] - later files
# win on shared keys). Copy this to .env.production and fill in real
# values before deploying; .env.production is gitignored, same as .env.
#
# Everything else (JWT_SECRET, GROQ_API_KEY, DATABASE_URL, etc.) still
# comes from .env - only put a key here if it must differ between local
# dev and production. Today that's just object storage: local dev uses
# the MinIO container from docker-compose.yml (see .env's STORAGE_*),
# while production needs a real S3-compatible provider reachable from the
# deploy target.

# Cloudflare R2 (or any other S3-compatible provider) - see .env.example's
# comment on STORAGE_ENDPOINT for the R2 URL format.
STORAGE_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=your_bucket_name
STORAGE_ACCESS_KEY_ID=your_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_secret_access_key
STORAGE_FORCE_PATH_STYLE=true
